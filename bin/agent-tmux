#!/usr/bin/env bash
set -euo pipefail

DELEGATE="${AGENT_TMUX_DELEGATE:-/usr/local/bin/agent-tmux}"
FULL_PERMISSION_ARGS=(-s danger-full-access -a never)

usage() {
    cat <<'EOF'
Usage:
  agent-tmux codex-full <session> <workdir> [codex-args...]
  agent-tmux codex-resume-full <session> <workdir> <thread-name-or-id> [prompt...]
  agent-tmux codex-resume-latest-full <session> <workdir> [prompt...]
  agent-tmux codex-existing <workdir> [preferred-session]
  agent-tmux <regular-agent-tmux-command> [...]

Full-permission aliases expand visibly to Codex args:
  -s danger-full-access -a never

Codex launch/resume routes require a new requested tmux session. If that session
already exists, the wrapper refuses before launching so prompts cannot be lost
inside a stale pane. Older same-repo sessions are ignored for these explicit
routes.

codex-existing is delegated, but an empty rc=1 absence result is normalized into
a clear stderr line for machine callers. Other regular commands are delegated
unchanged to /usr/local/bin/agent-tmux by default. Set AGENT_TMUX_DELEGATE to
test or override the delegated helper path.
EOF
}

die() {
    echo "agent-tmux: $*" >&2
    exit 2
}

resolved_path() {
    local path="$1"
    if command -v realpath >/dev/null 2>&1; then
        realpath -m "${path}"
        return
    fi
    case "${path}" in
        /*) printf "%s\n" "${path}" ;;
        *) printf "%s/%s\n" "${PWD}" "${path}" ;;
    esac
}

quote_command() {
    local quoted=""
    local arg
    for arg in "$@"; do
        if [[ -n "${quoted}" ]]; then
            quoted+=" "
        fi
        printf -v arg "%q" "${arg}"
        quoted+="${arg}"
    done
    printf "%s" "${quoted}"
}

require_delegate() {
    [[ -x "${DELEGATE}" ]] || die "delegated agent-tmux helper is not executable: ${DELEGATE}"
    if [[ "$(resolved_path "${DELEGATE}")" == "$(resolved_path "$0")" ]]; then
        die "AGENT_TMUX_DELEGATE resolves to this wrapper; refusing recursive delegation"
    fi
}

reject_bypass_arg() {
    local arg
    for arg in "$@"; do
        if [[ "${arg}" == "--dangerously-bypass-approvals-and-sandbox" ]]; then
            die "full-permission aliases must use -s danger-full-access -a never, not --dangerously-bypass-approvals-and-sandbox"
        fi
    done
}

is_full_permission_profile() {
    (($# >= 4)) || return 1
    [[ "$1" == "-s" && "$2" == "danger-full-access" && "$3" == "-a" && "$4" == "never" ]]
}

require_new_requested_session() {
    local session="$1"
    require_delegate
    if "${DELEGATE}" has "${session}" >/dev/null 2>&1; then
        die "requested session already exists: ${session}; choose a unique session name or stop it before launching"
    fi
}

delegate() {
    require_delegate
    if [[ "${AGENT_TMUX_SHOW_EFFECTIVE_COMMAND:-1}" != "0" ]]; then
        echo "agent-tmux: delegated command: $(quote_command "${DELEGATE}" "$@")" >&2
    fi
    exec "${DELEGATE}" "$@"
}

delegate_new_codex_session() {
    local session="$1"
    shift
    require_new_requested_session "${session}"
    if [[ "${AGENT_TMUX_SHOW_EFFECTIVE_COMMAND:-1}" != "0" ]]; then
        echo "agent-tmux: delegated command: AGENT_TMUX_ALLOW_DUPLICATE=1 $(quote_command "${DELEGATE}" "$@")" >&2
    fi
    AGENT_TMUX_ALLOW_DUPLICATE=1 exec "${DELEGATE}" "$@"
}

delegate_codex_existing() {
    (($# >= 1 && $# <= 2)) || die "codex-existing requires <workdir> [preferred-session]"
    require_delegate
    local stdout_file
    local stderr_file
    stdout_file="$(mktemp)"
    stderr_file="$(mktemp)"
    local rc=0
    set +e
    "${DELEGATE}" codex-existing "$@" >"${stdout_file}" 2>"${stderr_file}"
    rc=$?
    set -e
    local stdout_empty=0
    local stderr_empty=0
    [[ -s "${stdout_file}" ]] || stdout_empty=1
    [[ -s "${stderr_file}" ]] || stderr_empty=1
    if ((stdout_empty == 0)); then
        cat "${stdout_file}"
    fi
    if ((stderr_empty == 0)); then
        cat "${stderr_file}" >&2
    fi
    rm -f "${stdout_file}" "${stderr_file}"
    if ((rc == 1 && stdout_empty == 1 && stderr_empty == 1)); then
        echo "agent-tmux: no Codex tmux session found for workdir: $(resolved_path "$1")" >&2
    fi
    return "${rc}"
}

latest_thread_for_workdir() {
    local workdir="$1"
    require_delegate
    local stdout_file
    local stderr_file
    stdout_file="$(mktemp)"
    stderr_file="$(mktemp)"
    local rc=0
    set +e
    "${DELEGATE}" codex-latest "${workdir}" >"${stdout_file}" 2>"${stderr_file}"
    rc=$?
    set -e
    local latest_lines=()
    mapfile -t latest_lines <"${stdout_file}"
    local stderr_present=0
    [[ ! -s "${stderr_file}" ]] || stderr_present=1
    if ((rc != 0)); then
        if ((stderr_present)); then
            cat "${stderr_file}" >&2
        fi
        rm -f "${stdout_file}" "${stderr_file}"
        die "codex-latest failed for workdir: ${workdir}"
    fi
    if ((stderr_present)); then
        cat "${stderr_file}" >&2
        rm -f "${stdout_file}" "${stderr_file}"
        die "codex-latest wrote stderr for workdir: ${workdir}"
    fi
    rm -f "${stdout_file}" "${stderr_file}"
    ((${#latest_lines[@]} == 1)) || die "codex-latest returned malformed output for workdir: ${workdir}"
    local latest_line
    latest_line="${latest_lines[0]}"
    [[ -n "${latest_line}" ]] || die "codex-latest returned no session for workdir: ${workdir}"
    local thread_name
    local session_id
    local timestamp
    local path
    local extra
    IFS=$'\t' read -r thread_name session_id timestamp path extra <<<"${latest_line}"
    [[ -z "${extra:-}" && -n "${thread_name}" && -n "${session_id}" && -n "${timestamp}" && -n "${path}" ]] || die "codex-latest returned malformed output: ${latest_line}"
    printf "%s\n" "${thread_name}"
}

main() {
    local command="${1:-}"
    [[ -n "${command}" ]] || {
        usage
        exit 2
    }
    shift

    case "${command}" in
        codex-full)
            (($# >= 2)) || die "codex-full requires <session> <workdir> [codex-args...]"
            reject_bypass_arg "$@"
            local session="$1"
            local workdir="$2"
            shift 2
            delegate_new_codex_session "${session}" codex "${session}" "${workdir}" "${FULL_PERMISSION_ARGS[@]}" "$@"
            ;;
        codex-resume-full)
            (($# >= 3)) || die "codex-resume-full requires <session> <workdir> <thread-name-or-id> [prompt...]"
            reject_bypass_arg "$@"
            local session="$1"
            local workdir="$2"
            local thread_name="$3"
            shift 3
            local prompt_args=()
            if (($# > 0)); then
                prompt_args=("$*")
            fi
            delegate_new_codex_session "${session}" codex "${session}" "${workdir}" "${FULL_PERMISSION_ARGS[@]}" resume "${thread_name}" "${prompt_args[@]}"
            ;;
        codex-resume-latest-full)
            (($# >= 2)) || die "codex-resume-latest-full requires <session> <workdir> [prompt...]"
            reject_bypass_arg "$@"
            local session="$1"
            local workdir="$2"
            shift 2
            require_delegate
            require_new_requested_session "${session}"
            local thread_name
            thread_name="$(latest_thread_for_workdir "${workdir}")"
            local prompt_args=()
            if (($# > 0)); then
                prompt_args=("$*")
            fi
            delegate_new_codex_session "${session}" codex "${session}" "${workdir}" "${FULL_PERMISSION_ARGS[@]}" resume "${thread_name}" "${prompt_args[@]}"
            ;;
        codex)
            (($# >= 2)) || die "codex requires <session> <workdir> [codex-args...]"
            reject_bypass_arg "$@"
            local session="$1"
            local workdir="$2"
            shift 2
            delegate_new_codex_session "${session}" codex "${session}" "${workdir}" "$@"
            ;;
        codex-resume)
            (($# >= 3)) || die "codex-resume requires <session> <workdir> <thread-name-or-id> [prompt...]"
            reject_bypass_arg "$@"
            local session="$1"
            local workdir="$2"
            local thread_name="$3"
            shift 3
            if is_full_permission_profile "$@"; then
                shift 4
                local prompt_args=()
                if (($# > 0)); then
                    prompt_args=("$*")
                fi
                delegate_new_codex_session "${session}" codex "${session}" "${workdir}" "${FULL_PERMISSION_ARGS[@]}" resume "${thread_name}" "${prompt_args[@]}"
            fi
            delegate_new_codex_session "${session}" "${command}" "${session}" "${workdir}" "${thread_name}" "$@"
            ;;
        codex-resume-latest)
            (($# >= 2)) || die "codex-resume-latest requires <session> <workdir> [prompt...]"
            reject_bypass_arg "$@"
            local session="$1"
            local workdir="$2"
            shift 2
            if is_full_permission_profile "$@"; then
                shift 4
                require_delegate
                require_new_requested_session "${session}"
                local thread_name
                thread_name="$(latest_thread_for_workdir "${workdir}")"
                local prompt_args=()
                if (($# > 0)); then
                    prompt_args=("$*")
                fi
                delegate_new_codex_session "${session}" codex "${session}" "${workdir}" "${FULL_PERMISSION_ARGS[@]}" resume "${thread_name}" "${prompt_args[@]}"
            fi
            delegate_new_codex_session "${session}" "${command}" "${session}" "${workdir}" "$@"
            ;;
        -h|--help|help)
            usage
            ;;
        codex-existing)
            delegate_codex_existing "$@"
            ;;
        *)
            require_delegate
            exec "${DELEGATE}" "${command}" "$@"
            ;;
    esac
}

main "$@"
